# Stripe secret key from Developers > API keys.
STRIPE_SECRET_KEY=sk_test_...

# Full site origin with no trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# One-time Stripe Price IDs. These begin with price_, not prod_.
STRIPE_PRICE_HONEY_500G=price_...
STRIPE_PRICE_HONEY_1KG=price_...
STRIPE_PRICE_HONEYCOMB_500G=price_...
